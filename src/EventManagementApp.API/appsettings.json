{
  "App": {
    "BaseUrl": "http://localhost:5270"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=EventManagementAppDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Secret": "EventManagementApp_SuperSecret_Key_Min32Chars!",
    "Issuer": "EventManagementApp",
